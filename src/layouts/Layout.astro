---
import { Toaster } from '@/components/ui/sonner'
import '../styles/global.css'
import { InteractiveCVPageHeader } from '@/components/custom/InteractiveCVPageHeader'
---

<!doctype html>
<html
	lang='en'
	class='dark antialiased font-mono'
>
	<head>
		<meta charset='UTF-8' />
		<meta
			name='viewport'
			content='width=device-width'
		/>
		<title>Luke De Kiewit CV</title>
		<meta
			name='description'
			content='My interactive CV web page - built with Astro, React, TypeScript, Tailwind CSS and shadcn/ui.'
		/>
		<meta
			name='lang'
			content='en'
		/>
		<meta
			name='author'
			content='Luke De Kiewit'
		/>
		<meta
			name='robots'
			content='noindex, nofollow'
		/>
		<meta
			name='googlebot'
			content='noindex, nofollow'
		/>
		<meta
			name='bingbot'
			content='noindex'
		/>
		<link
			rel='canonical'
			href='https://example.com/'
		/>
		<link
			rel='icon'
			href='/images/favicon.ico'
		/>
		<script is:inline>
			const getThemePreference = () => {
				if (
					typeof localStorage !== 'undefined' &&
					localStorage.getItem('theme')
				) {
					return localStorage.getItem('theme')
				}
				return window.matchMedia('(prefers-color-scheme: dark)').matches
					? 'dark'
					: 'light'
			}
			const isDark = getThemePreference() === 'dark'
			document.documentElement.classList[isDark ? 'add' : 'remove']('dark')

			if (typeof localStorage !== 'undefined') {
				const observer = new MutationObserver(() => {
					const isDark = document.documentElement.classList.contains('dark')
					localStorage.setItem('theme', isDark ? 'dark' : 'light')
				})
				observer.observe(document.documentElement, {
					attributes: true,
					attributeFilter: ['class']
				})
			}
		</script>
	</head>
	<body>
		<InteractiveCVPageHeader
			lightModeLogo={{
				src: '/images/logos/ldk_logo_black_tilted_724px.png',
				alt: 'Luke De Kiewit logo'
			}}
			darkModeLogo={{
				src: '/images/logos/ldk_logo_atomwave_tilted_724px.png',
				alt: 'Luke De Kiewit logo'
			}}
			lastUpdated='20/12/2025'
			shareLink='https://cv.lukedekiewit.co.za/'
			client:load
		/>
		<main class='p-4 md:p-6 lg:p-8'><slot /></main>
	</body>
	<Toaster
		client:load
		position='bottom-center'
	/>
</html>
