---
import "../styles/global.css";
import { InteractiveCVPageHeader } from "@/components/custom/InteractiveCVPageHeader";
---

<!doctype html>
<html lang="en" class="dark antialiased font-mono">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Luke De Kiewit CV</title>
    <meta
      name="description"
      content="My interactive CV web page - built with Astro, React, TypeScript, Tailwind CSS and shadcn/ui."
    />
    <meta name="lang" content="en" />
    <meta name="author" content="Luke De Kiewit" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="googlebot" content="noindex, nofollow" />
    <meta name="bingbot" content="noindex" />
    <link rel="canonical" href="https://example.com/" />
    <link rel="icon" href="/images/favicon.ico" />
  </head>
  <body>
    <InteractiveCVPageHeader
      avatar={{
        src: "/images/ldk_matrix_avatar_1024px.png",
        alt: "Luke De Kiewit profile picture",
      }}
      lastUpdated="20/12/2025"
      shareLink="https://cv.lukedekiewit.co.za/"
      client:load
    />
    <main class="p-4 md:p-6 lg:p-8"><slot /></main>
  </body>
</html>
