---
import { CV } from "@/components/custom/cv/cv";
import Layout from "@/components/custom/layout/layout.astro";
import laptopCodeBg from "@/assets/images/backgrounds/laptop_code_3.jpg";
import avatar from "@/assets/images/ldk_selfie_pfp_filter_800px.png";
import { optimizeImage } from "@/lib/optimize-images";

const optimizedLaptopCodeBg = await optimizeImage(laptopCodeBg, "webp", 1920);
const optimizedAvatarImage = await optimizeImage(avatar, "webp", 512);
---

<Layout>
  <CV
    client:load
    backgroundImage={optimizedLaptopCodeBg.src}
    avatar={optimizedAvatarImage}
  />
</Layout>
