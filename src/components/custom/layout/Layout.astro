---
import "../../../styles/global.css";
import { Toaster } from "@/components/ui/sonner";
import { PageHeader } from "./PageHeader";
---

<!doctype html>
<html lang="en" class="dark antialiased">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Luke De Kiewit CV</title>
    <meta
      name="description"
      content="My interactive CV web page - built with Astro, React, TypeScript, Tailwind CSS and shadcn/ui."
    />
    <meta name="lang" content="en" />
    <meta name="author" content="Luke De Kiewit" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="googlebot" content="noindex, nofollow" />
    <meta name="bingbot" content="noindex" />
    <link rel="canonical" href="https://example.com/" />
    <link rel="icon" href="/images/favicon.ico" />
    <script is:inline>
      const getThemePreference = () => {
        if (
          typeof localStorage !== "undefined" &&
          localStorage.getItem("theme")
        ) {
          return localStorage.getItem("theme");
        }
        return window.matchMedia("(prefers-color-scheme: dark)").matches
          ? "dark"
          : "light";
      };
      const isDark = getThemePreference() === "dark";
      document.documentElement.classList[isDark ? "add" : "remove"]("dark");

      if (typeof localStorage !== "undefined") {
        const observer = new MutationObserver(() => {
          const isDark = document.documentElement.classList.contains("dark");
          localStorage.setItem("theme", isDark ? "dark" : "light");
        });
        observer.observe(document.documentElement, {
          attributes: true,
          attributeFilter: ["class"],
        });
      }
    </script>
  </head>
  <body class="min-h-fit font-mono animate-in fade-in duration-1000">
    <PageHeader
      lightModeLogo={{
        src: "/images/logos/ldk_logo_black_tilted_724px.png",
        alt: "Luke De Kiewit logo",
        height: 40,
        width: 40,
        loading: "eager",
        title: "Luke De Kiewit Logo",
      }}
      darkModeLogo={{
        src: "/images/logos/ldk_logo_atomwave_tilted_724px.png",
        alt: "Luke De Kiewit logo",
        height: 40,
        width: 40,
        loading: "eager",
        title: "Luke De Kiewit Logo",
      }}
      lastUpdated="24/12/2025"
      shareLink="https://cv.lukedekiewit.co.za/"
      pdfDownloadLink="/images/logos/ldk_logo_atomwave_square_512px.png"
      client:load
    />
    <slot />
    <Toaster client:load position="bottom-center" />
  </body>
</html>
