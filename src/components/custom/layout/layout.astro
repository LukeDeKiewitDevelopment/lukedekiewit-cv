---
import "@/styles/global.css";
import { Toaster } from "@/components/ui/sonner";
import { Header } from "./header";
import { Footer } from "./footer";
import { SiteBackground } from "./site-background";
import { BackToTop } from "../back-to-top";
import { SEO } from "astro-seo-plugin";
import codeBackground from "@/assets/images/backgrounds/codeBackground.jpg";
import lightmodeLogo from "@/assets/images/logos/ldk_logo_black_tilted_724px.png";
import darkmodeLogo from "@/assets/images/logos/ldk_logo_atomwave_tilted_724px.png";
import { optimizeImage } from "@/lib/optimize-images";
import type { AstroSEO } from "@/lib/seo";

interface Props {
  hideNavbar?: boolean;
  hideDownloadButton?: boolean;
  hidePrintButton?: boolean;
  hideProjectsButton?: boolean;
  showBackToCvButton?: boolean;
  seo?: AstroSEO;
}

const optimizedCodeBackground = await optimizeImage(
  codeBackground,
  "webp",
  1920,
);

const optimizedLightmodeLogo = await optimizeImage(lightmodeLogo, "webp", 512);

const optimizedDarkmodeLogo = await optimizeImage(darkmodeLogo, "webp", 512);

const {
  hideNavbar,
  hideDownloadButton,
  hidePrintButton,
  hideProjectsButton,
  showBackToCvButton,
  seo,
} = Astro.props;
---

<!doctype html>
<html
  lang="en"
  class="dark antialiased w-screen h-screen print:w-auto print:h-auto print:overflow-hidden"
>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="lang" content="en" />
    <meta name="author" content="Luke De Kiewit" />

    <!-- 
    Old, static implementation
    
    <AstroSEO
      title="Luke De Kiewit | Frontend Engineer"
      description="Luke De Kiewit is a Frontend Engineer specialising in high-quality frontend systems, websites, and UI libraries. Skilled in React, TypeScript, Astro, Tailwind CSS, and Shopify Liquid."
      openGraph={{
        title: "Luke De Kiewit | Frontend Engineer",
        description:
          "Luke De Kiewit is a Frontend Engineer specialising in high-quality frontend systems, websites, and UI libraries. Skilled in React, TypeScript, Astro, Tailwind CSS, and Shopify Liquid.",
        image: "https://lukedekiewit-cv.vercel.app/images/ldk_selfie_pfp.webp",
        type: "profile",
      }}
      jsonLd={{
        "@type": "Person",
        name: "Luke De Kiewit",
        jobTitle: "Frontend Engineer",
        url: "https://lukedekiewit-cv.vercel.app/",
        email: "luke.dekiewit@yahoo.com",
        sameAs: [
          "https://github.com/lukedekiewit",
          "https://www.linkedin.com/in/lukedekiewit/",
        ],
        address: {
          "@type": "PostalAddress",
          addressLocality: "Bloemfontein",
          addressRegion: "Free State",
          addressCountry: "ZA",
        },
      }}
      robots={{
        index: true,
        follow: true,
        noarchive: false,
        nosnippet: false,
        maxSnippet: 150,
      }}
      additionalLinkTags={[{ rel: "canonical", href: Astro.url.href }]}
      additionalMetaTags={[
        {
          name: "keywords",
          content:
            "Luke De Kiewit, Frontend Engineer, Web Developer, React, TypeScript, Astro, Tailwind CSS, Shopify Liquid, Shopify, JavaScript, CV, Resume, South Africa, Bloemfontein",
        },
      ]}
    /> -->
    <link rel="icon" href="/images/favicon.ico" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <!-- Astro SEO  -->
    <SEO {...seo} />
    <!---------------->
    <script is:inline>
      const getThemePreference = () => {
        if (
          typeof localStorage !== "undefined" &&
          localStorage.getItem("theme")
        ) {
          return localStorage.getItem("theme");
        }
        return window.matchMedia("(prefers-color-scheme: dark)").matches
          ? "dark"
          : "light";
      };

      const isDark = getThemePreference() === "dark";
      document.documentElement.classList[isDark ? "add" : "remove"]("dark");

      if (typeof localStorage !== "undefined") {
        const observer = new MutationObserver(() => {
          const isDark = document.documentElement.classList.contains("dark");
          localStorage.setItem("theme", isDark ? "dark" : "light");
        });
        observer.observe(document.documentElement, {
          attributes: true,
          attributeFilter: ["class"],
        });
      }
    </script>
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-2SJ2DJ8GZL"
    ></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];

      function gtag() {
        dataLayer.push(arguments);
      }

      gtag("js", new Date());

      gtag("config", "G-2SJ2DJ8GZL");
    </script>
  </head>
  <body
    class="size-full overflow-x-hidden print:overflow-hidden scrollbar-gutter-stable scroll-smooth"
  >
    {
      !hideNavbar && (
        <Header
          lightModeLogo={optimizedLightmodeLogo}
          darkModeLogo={optimizedDarkmodeLogo}
          shareLink="https://lukedekiewit-cv.vercel.app/"
          pdfDownloadLink="/files/Luke_De_Kiewit_FrontendEngineer_latest.pdf"
          hideDownloadButton={hideDownloadButton}
          hidePrintButton={hidePrintButton}
          hideProjectsButton={hideProjectsButton}
          showBackToCvButton={showBackToCvButton}
          client:load
        />
      )
    }

    <slot />
    <Footer client:load />
    <BackToTop client:load />
    <Toaster client:load position="bottom-center" className="print:hidden!" />
    <SiteBackground
      client:load
      backgroundImage={{
        className: "grayscale opacity-20 dark:opacity-10 print:hidden!",
        src: optimizedCodeBackground.src,
      }}
    />
  </body>
</html>
