---
import "../../../styles/global.css";
import { Toaster } from "@/components/ui/sonner";
import { Header } from "./header";
import { Footer } from "./footer";
import { SiteBackground } from "./site-background";
import { BackToTop } from "../back-to-top";
import { AstroSEO } from "astro-seo-plugin";

import { getImage } from "astro:assets";
import code3Bg from "@/assets/images/backgrounds/code_3.jpg";

const optimizedCode3Bg = await getImage({
  src: code3Bg,
  format: "webp",
  width: 1920,
});

const {
  hideNavbar,
  hideDownloadButton,
  hidePrintButton,
  hideProjectsButton,
  showBackToCvButton,
} = Astro.props;
---

<!doctype html>
<html
  lang="en"
  class="dark antialiased w-screen h-screen print:w-auto print:h-auto print:overflow-hidden"
>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="lang" content="en" />
    <meta name="author" content="Luke De Kiewit" />

    <AstroSEO
      title="Luke De Kiewit | Front-End Engineer"
      description="Luke De Kiewit is a Front-End Engineer specialising in high-quality front-end systems, websites, and UI libraries. Skilled in React, TypeScript, Astro, Tailwind CSS, and Shopify Liquid."
      openGraph={{
        title: "Luke De Kiewit | Front-End Engineer",
        description:
          "Luke De Kiewit is a Front-End Engineer specialising in high-quality front-end systems, websites, and UI libraries. Skilled in React, TypeScript, Astro, Tailwind CSS, and Shopify Liquid.",
        image: "https://lukedekiewit-cv.vercel.app/images/ldk_selfie_pfp.webp",
        type: "profile",
      }}
      jsonLd={{
        "@type": "Person",
        name: "Luke De Kiewit",
        jobTitle: "Front-End Engineer",
        url: "https://lukedekiewit-cv.vercel.app/",
        email: "luke.dekiewit@yahoo.com",
        sameAs: [
          "https://github.com/lukedekiewit",
          "https://www.linkedin.com/in/lukedekiewit/",
        ],
        address: {
          "@type": "PostalAddress",
          addressLocality: "Bloemfontein",
          addressRegion: "Free State",
          addressCountry: "ZA",
        },
      }}
      robots={{
        index: true,
        follow: true,
        noarchive: false,
        nosnippet: false,
        maxSnippet: 150,
      }}
      additionalLinkTags={[
        { rel: "canonical", href: "https://lukedekiewit-cv.vercel.app/" },
      ]}
      additionalMetaTags={[
        {
          name: "keywords",
          content:
            "Luke De Kiewit, Front-End Engineer, Web Developer, React, TypeScript, Astro, Tailwind CSS, Shopify Liquid, Shopify, JavaScript, CV, Resume, South Africa, Bloemfontein",
        },
      ]}
    />
    <link rel="icon" href="/images/favicon.ico" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <script is:inline>
      const getThemePreference = () => {
        if (
          typeof localStorage !== "undefined" &&
          localStorage.getItem("theme")
        ) {
          return localStorage.getItem("theme");
        }
        return window.matchMedia("(prefers-color-scheme: dark)").matches
          ? "dark"
          : "light";
      };

      const isDark = getThemePreference() === "dark";
      document.documentElement.classList[isDark ? "add" : "remove"]("dark");

      if (typeof localStorage !== "undefined") {
        const observer = new MutationObserver(() => {
          const isDark = document.documentElement.classList.contains("dark");
          localStorage.setItem("theme", isDark ? "dark" : "light");
        });
        observer.observe(document.documentElement, {
          attributes: true,
          attributeFilter: ["class"],
        });
      }
    </script>
  </head>
  <body
    class="size-full overflow-x-hidden print:overflow-hidden scrollbar-gutter-stable scroll-smooth"
  >
    {
      !hideNavbar && (
        <Header
          lightModeLogo={{
            src: "/images/logos/ldk_logo_black_tilted_128px.webp",
            alt: "Luke De Kiewit logo",
            height: 40,
            width: 40,
            loading: "eager",
            title: "Luke De Kiewit Logo",
          }}
          darkModeLogo={{
            src: "/images/logos/ldk_logo_atomwave_tilted_128px.webp",
            alt: "Luke De Kiewit logo",
            height: 40,
            width: 40,
            loading: "eager",
            title: "Luke De Kiewit Logo",
          }}
          lastUpdated="14 May 2026"
          shareLink="https://lukedekiewit-cv.vercel.app/"
          pdfDownloadLink="/files/Luke_De_Kiewit_FrontendEngineer_latest.pdf"
          hideDownloadButton={hideDownloadButton}
          hidePrintButton={hidePrintButton}
          hideProjectsButton={hideProjectsButton}
          showBackToCvButton={showBackToCvButton}
          client:load
        />
      )
    }

    <slot />
    <Footer client:load />
    <BackToTop client:load />
    <Toaster client:load position="bottom-center" className="print:hidden!" />
    <SiteBackground
      client:load
      backgroundImage={{
        className: "grayscale opacity-10 hidden dark:block print:hidden!",
        src: optimizedCode3Bg.src,
      }}
    />
  </body>
</html>
