{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "baseUrl": ".",
    "paths": {
      "@ui/*": ["./src/components/ui/*"],
      "@cv/*": ["./src/components/custom/cv/*"],
      "@layout/*": ["./src/components/layout/*"],
      "@lib/*": ["./src/lib/*"]
    }
  }
}
